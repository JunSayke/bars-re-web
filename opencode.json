{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "next-devtools": {
      "type": "local",
      "command": ["npx", "-y", "next-devtools-mcp@latest"],
      "enabled": true,
      "environment": {}
    },
    "supabase": {
      "type": "remote",
      "url": "http://localhost:54321/mcp",
      "enabled": true
    },
    "jupyter": {
      "type": "local",
      "command": ["uvx", "jupyter-mcp-server@latest"],
      "environment": {
        "JUPYTER_URL": "http://localhost:8888",
        "JUPYTER_TOKEN": "OPENCODE_TOKEN",
        "ALLOW_IMG_OUTPUT": "true"
      },
      "enabled": true
    }
  }
}

