create table public.beat_files (
  id uuid not null default gen_random_uuid (),
  session_id uuid not null,
  storage_path character varying(500) null,
  bpm integer null,
  file_size_bytes integer null,
  source_type character varying(20) null,
  constraint beat_files_pkey primary key (id),
  constraint beat_files_session_id_fkey foreign KEY (session_id) references sessions (id) on delete CASCADE
) TABLESPACE pg_default;